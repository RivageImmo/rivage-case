{
  "all": {
    "sourceCodeDir": "app/frontend",
    "entrypointsDir": "entrypoints",
    "autoBuild": true,
    "watchAdditionalPaths": ["app/frontend/**/*.{js,jsx,ts,tsx,scss}"]
  },
  "development": {
    "autoBuild": true,
    "publicOutputDir": "vite-dev",
    "port": 5173
  },
  "test": {
    "autoBuild": true,
    "publicOutputDir": "vite-test",
    "port": 3037
  },
  "production": {
    "autoBuild": false,
    "publicOutputDir": "vite"
  }
}
